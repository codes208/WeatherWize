<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alerts Manager - WeatherWize</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/weatherWize.CSS">
    <script src="/js/toast.js"></script>
    <script src="/js/utils.js"></script>
    <script src="/js/auth-check.js" defer></script>
    <script src="/js/alerts-manager.js" defer></script>
</head>

<body data-allowed-roles="advanced,admin" class="dashboard-page">
    <div class="sky-wrap" aria-hidden="true">
        <div class="cloud cloud-1"></div>
        <div class="cloud cloud-2"></div>
        <div class="cloud cloud-3"></div>
    </div>
    <nav class="navbar">
        <div class="container nav-content">
            <a href="/dashboard" class="nav-brand">
                <img src="/images/weatherewize_logo.png" alt="WeatherWize Logo" class="nav-logo">
                WeatherWize
            </a>
            <div class="nav-right">
                <a href="/profile" id="username-display"></a>
                <button id="logout-btn" class="btn">Logout</button>
            </div>
        </div>
    </nav>
    <main class="container dashboard-content">
        <h2 class="text-center">Weather Alerts</h2>
        <div class="auth-card auth-card-sm">
            <span id="alert-message" class="location-msg"></span>
            <div class="form-group">
                <label>Location</label>
                <select id="alert-location">
                    <option disabled selected>Loading locations...</option>
                </select>
            </div>
            <div class="form-group">
                <label>Metric</label>
                <select id="alert-trigger">
                    <option value="Temperature">Temperature (°F)</option>
                    <option value="Humidity">Humidity (%)</option>
                    <option value="Wind Speed">Wind Speed (mph)</option>
                </select>
            </div>
            <div class="alert-form-row">
                <div class="form-group alert-form-col">
                    <label>Min</label>
                    <input type="number" id="alert-threshold-min" placeholder="e.g. 32">
                </div>
                <div class="form-group alert-form-col">
                    <label>Max</label>
                    <input type="number" id="alert-threshold-max" placeholder="e.g. 90">
                </div>
            </div>
            <p class="alert-form-hint">You'll be alerted when the value goes outside this range.</p>
            <button id="save-alert-btn" class="btn btn-block">Save Alert</button>
        </div>

        <h3 class="alerts-section-heading">Active Alerts</h3>
        <div id="alerts-list">
            <% if (alerts.length === 0) { %>
                <p class="alerts-empty">No alerts configured.</p>
            <% } else { %>
                <% alerts.forEach(alert => { %>
                    <div class="location-card alert-card <%= alert.is_active ? 'alert-card--active' : 'alert-card--inactive' %>">
                        <h4>
                            <%= alert.location_name %>
                            <% if (!alert.is_active) { %>
                                <span class="alert-inactive-label">(inactive)</span>
                            <% } %>
                        </h4>
                        <p class="alert-card-detail">Alert when: <%= alert.trigger_type %> is outside <%= alert.threshold_value %> – <%= alert.threshold_max %></p>
                        <div class="alert-card-buttons">
                            <% if (!alert.is_active) { %>
                                <button class="btn btn-sm" data-id="<%= alert.id %>" data-action="enable">Re-enable</button>
                            <% } else { %>
                                <button class="btn-disable" data-id="<%= alert.id %>" data-action="disable" data-location="<%= alert.location_name %>">Disable</button>
                            <% } %>
                            <button class="delete-location-btn" data-id="<%= alert.id %>" data-action="delete" data-location="<%= alert.location_name %>">Delete</button>
                        </div>
                        <span class="location-msg"></span>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>
</body>

</html>
