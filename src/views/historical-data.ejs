<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Historical Data - WeatherWize</title>
    <link rel="stylesheet" href="./css/style.css">
    <link rel="stylesheet" href="./css/weatherWize.CSS">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="./js/toast.js"></script>
    <script src="./js/utils.js"></script>
    <script src="./js/auth-check.js" defer></script>
    <script src="./js/historical-data.js" defer></script>
</head>

<body data-allowed-roles="advanced,admin" class="dashboard-page">
    <div class="sky-wrap" aria-hidden="true">
        <div class="cloud cloud-1"></div>
        <div class="cloud cloud-2"></div>
        <div class="cloud cloud-3"></div>
    </div>
    <nav class="navbar">
        <div class="container nav-content">
            <a href="/dashboard" class="nav-brand">
                <img src="./images/weatherewize_logo.png" alt="WeatherWize Logo" class="nav-logo">
                WeatherWize
            </a>
            <div class="nav-right">
                <a href="/profile" id="username-display"></a>
                <button id="logout-btn" class="btn">Logout</button>
            </div>
        </div>
    </nav>

    <main class="container dashboard-content page-centered">
        <h2 class="text-center">Historical Weather Trends</h2>
        <span id="history-msg" class="location-msg"></span>

        <div class="auth-card auth-card-lg">

            <!-- Location & Date Range -->
            <div class="history-controls">
                <div class="form-group">
                    <label>Location</label>
                    <select id="history-location">
                        <option disabled selected>Loading locations...</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Start Date</label>
                    <input type="date" id="history-start-date">
                </div>
                <div class="form-group">
                    <label>End Date</label>
                    <input type="date" id="history-end-date">
                </div>
            </div>

            <!-- Trend Selectors -->
            <div class="form-group trend-section">
                <label>Select Trends to Display</label>
                <div class="trend-grid">
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="temperature" checked>
                        Temperature (High / Low °F)
                    </label>
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="feelsLike">
                        Feels Like (High / Low °F)
                    </label>
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="precipitation">
                        Total Precipitation (in)
                    </label>
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="rain">
                        Rainfall (in)
                    </label>
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="snowfall">
                        Snowfall (in)
                    </label>
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="wind">
                        Max Wind Speed (mph)
                    </label>
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="gusts">
                        Wind Gusts (mph)
                    </label>
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="sunshine">
                        Sunshine Duration (min)
                    </label>
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="aqi">
                        Air Quality Index (US AQI)
                    </label>
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="pm25">
                        PM2.5 (μg/m³)
                    </label>
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="pm10">
                        PM10 (μg/m³)
                    </label>
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="ozone">
                        Ozone (μg/m³)
                    </label>
                    <label class="trend-checkbox">
                        <input type="checkbox" name="trend" value="no2">
                        Nitrogen Dioxide (μg/m³)
                    </label>
                </div>
            </div>

            <button id="fetch-history-btn" class="btn btn-block">
                Fetch Historical Data
            </button>

            <!-- Chart -->
            <div id="chart-container">
                <p class="chart-placeholder">
                    Select a location, date range, and trends — then click "Fetch Historical Data".
                    <br><small class="chart-note">Maximum range: 365 days. Air quality data available from 2013 onwards. All other weather data available from 1940.</small>
                </p>
            </div>
        </div>
    </main>
</body>

</html>
