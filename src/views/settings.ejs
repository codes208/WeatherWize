<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Settings - WeatherWize Admin</title>
    <link rel="stylesheet" href="./css/style.css">
    <link rel="stylesheet" href="./css/weatherWize.CSS">
    <script src="./js/toast.js"></script>
    <script src="./js/utils.js"></script>
    <script src="./js/auth-check.js" defer></script>
    <script src="./js/settings.js" defer></script>
</head>

<body data-allowed-roles="admin" class="dashboard-page">
    <div class="sky-wrap" aria-hidden="true">
        <div class="cloud cloud-1"></div>
        <div class="cloud cloud-2"></div>
        <div class="cloud cloud-3"></div>
    </div>
    <nav class="navbar">
        <div class="container nav-content">
            <a href="/dashboard" class="nav-brand">
                <img src="./images/weatherewize_logo.png" alt="WeatherWize Logo" class="nav-logo">
                WeatherWize
            </a>
            <div class="nav-right">
                <a href="/profile" id="username-display"></a>
                <button id="logout-btn" class="btn" onclick="window.location.href='/'">Logout</button>
            </div>
        </div>
    </nav>
    <main class="container dashboard-content page-centered">
        <h2 class="text-center">Global System Settings</h2>

        <div class="auth-card auth-card-lg">
            <div class="form-group settings-toggle-row">
                <div>
                    <h3 class="settings-section-title">Maintenance Mode</h3>
                    <p class="settings-section-desc">Disconnects all non-admin users and
                        shows maintenance screen.</p>
                </div>
                <label class="settings-toggle-label">
                    <input type="checkbox" id="maintenance-toggle"> Enable
                </label>
            </div>

            <span id="settings-message" class="location-msg"></span>
            <button id="save-settings-btn" class="btn btn-block">Save System Configuration</button>
        </div>
    </main>
</body>

</html>