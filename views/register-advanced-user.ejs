<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Advanced User Account - WeatherWize</title>
    <link rel="stylesheet" href="./css/style.css">
    <link rel="stylesheet" href="./css/weatherWize.CSS">
    <script src="./js/toast.js"></script>
    <script src="./js/auth.js" defer></script>
</head>

<body class="register-page">
    <a href="/" class="page-logo-link" aria-label="WeatherWize home">
        <img src="./images/weatherewize_logo.png" alt="WeatherWize logo" class="page-logo">
    </a>
    <div class="sky-wrap" aria-hidden="true">
        <div class="cloud still-cloud still-cloud-1"></div>
        <div class="cloud still-cloud still-cloud-2"></div>
        <div class="cloud still-cloud still-cloud-3"></div>
    </div>
    <div class="auth-container">
        <div class="auth-card">
            <h2 class="auth-title">Create Advanced Account</h2>
            <p class="account-choice-subtitle">Paid tier with expanded weather features.</p>
            <p class="advanced-price-badge">$9.99 / month</p>
            <form id="register-form">
                <div id="register-error" class="text-danger text-center hidden"></div>
                <input type="hidden" name="role" value="advanced">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" required>
                </div>
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required>
                </div>
                <div class="form-group">
                    <label for="confirmPassword">Confirm Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" required>
                </div>
                <div class="payment-divider">Payment Information</div>
                <div class="form-group">
                    <label for="cardNumber">Card Number</label>
                    <input type="text" id="cardNumber" name="cardNumber" placeholder="1234 5678 9012 3456"
                        maxlength="19" inputmode="numeric" required>
                </div>
                <div class="payment-row">
                    <div class="form-group">
                        <label for="cardExpiry">Expiry Date</label>
                        <input type="text" id="cardExpiry" name="cardExpiry" placeholder="MM/YY" maxlength="5"
                            inputmode="numeric" required>
                    </div>
                    <div class="form-group">
                        <label for="cardCvv">CVV</label>
                        <input type="text" id="cardCvv" name="cardCvv" placeholder="123" maxlength="3"
                            inputmode="numeric" required>
                    </div>
                </div>
                <button type="submit" class="btn btn-block">Create Advanced Account</button>
            </form>
            <div class="auth-link">
                <p>Need the free plan? <a href="/register-general-user">Register as General</a></p>
            </div>
            <div class="auth-link">
                <p>Choose another account type? <a href="/select-account-type">Back to account options</a></p>
            </div>
        </div>
    </div>
</body>

</html>