<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alerts Manager - WeatherWize</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/weatherWize.CSS">
    <script src="/js/toast.js"></script>
    <script src="/js/auth-check.js" defer></script>
    <script src="/js/alerts-manager.js" defer></script>
</head>

<body data-allowed-roles="advanced,admin" class="dashboard-page">
    <div class="sky-wrap" aria-hidden="true">
        <div class="cloud cloud-1"></div>
        <div class="cloud cloud-2"></div>
        <div class="cloud cloud-3"></div>
    </div>
    <nav class="navbar">
        <div class="container nav-content">
            <a href="/dashboard" class="nav-brand">
                <img src="/images/weatherewize_logo.png" alt="WeatherWize Logo" class="nav-logo"
                    style="display:inline-block; vertical-align:middle;">
                WeatherWize
            </a>
            <div class="nav-right">
                <a href="profile.html" id="username-display" style="font-weight: bold; text-decoration: none;"></a>
                <button id="logout-btn" class="btn">Logout</button>
            </div>
        </div>
    </nav>
    <main class="container dashboard-content">
        <h2 style="text-align:center;">Severe Weather Alerts</h2>
        <div class="auth-card" style="max-width: 600px; margin: 20px auto 0;">
            <div id="alert-message" class="text-center" style="margin-bottom: 15px; display: none;"></div>
            <div class="form-group">
                <label>Location</label>
                <select id="alert-location">
                    <option disabled selected>Loading locations...</option>
                </select>
            </div>
            <div class="form-group">
                <label>Metric</label>
                <select id="alert-trigger">
                    <option value="Temperature">Temperature (°F)</option>
                    <option value="Humidity">Humidity (%)</option>
                    <option value="Wind Speed">Wind Speed (mph)</option>
                </select>
            </div>
            <div style="display: flex; gap: 12px;">
                <div class="form-group" style="flex: 1;">
                    <label>Min</label>
                    <input type="number" id="alert-threshold-min" placeholder="e.g. 32">
                </div>
                <div class="form-group" style="flex: 1;">
                    <label>Max</label>
                    <input type="number" id="alert-threshold-max" placeholder="e.g. 90">
                </div>
            </div>
            <p style="font-size: 0.82rem; color: var(--text-secondary); margin-top: -5px;">You'll be alerted when the value goes outside this range.</p>
            <button id="save-alert-btn" class="btn btn-block">Save Alert</button>
        </div>

        <h3 style="margin-top: 40px;">Active Alerts</h3>
        <div id="alerts-list">
            <% if (alerts.length === 0) { %>
                <p style="color: var(--text-secondary); text-align: center;">No alerts configured.</p>
            <% } else { %>
                <% alerts.forEach(alert => { %>
                    <div class="location-card" style="margin-top: 15px; border-left: 4px solid <%= alert.is_active ? 'var(--danger)' : 'var(--border)' %>; opacity: <%= alert.is_active ? '1' : '0.6' %>;">
                        <h4>
                            <%= alert.location_name %>
                            <% if (!alert.is_active) { %>
                                <span style="font-size:0.75rem; color:var(--text-secondary);">(triggered — inactive)</span>
                            <% } %>
                        </h4>
                        <p style="color: var(--text-secondary);">Alert when: <%= alert.trigger_type %> is outside <%= alert.threshold_value %> – <%= alert.threshold_max %></p>
                        <div style="display:flex; gap:8px; margin-top:8px;">
                            <% if (!alert.is_active) { %>
                                <button class="btn" style="font-size:0.82rem; padding:6px 12px;" data-id="<%= alert.id %>" data-action="enable">Re-enable</button>
                            <% } %>
                            <button class="delete-location-btn" data-id="<%= alert.id %>" data-action="delete">Delete</button>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>
</body>

</html>
