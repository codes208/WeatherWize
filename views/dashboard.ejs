<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - WeatherWize</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/weatherWize.CSS">
    <% if (role === 'advanced') { %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <% } %>
    <script src="/js/toast.js"></script>
    <script src="/js/utils.js"></script>
    <script src="/js/auth-check.js" defer></script>
    <script src="/js/weather-dashboard.js" defer></script>
</head>

<body data-allowed-roles="general,advanced,admin" class="dashboard-page">
    <div class="sky-wrap" aria-hidden="true">
        <div class="cloud cloud-1"></div>
        <div class="cloud cloud-2"></div>
        <div class="cloud cloud-3"></div>
    </div>

    <nav class="navbar">
        <div class="container nav-content">
            <a href="/dashboard" class="nav-brand">
                <img src="/images/weatherewize_logo.png" alt="WeatherWize Logo" class="nav-logo">
                WeatherWize
            </a>
            <div class="nav-links">
                <% if (role === 'advanced') { %>
                <button class="btn btn-text" onclick="window.location.href='historical-data.html'">Historical Data</button>
                <button class="btn btn-text" onclick="window.location.href='/alerts-manager'">Manage Alerts</button>
                <button class="btn btn-text" onclick="window.location.href='map.html'">Map</button>
                <% } %>
                <button class="btn btn-text" onclick="window.location.href='locations.html'">Manage Locations</button>
            </div>
            <div class="nav-right">
                <a href="profile.html" id="username-display"></a>
                <button id="logout-btn" class="btn">Logout</button>
            </div>
        </div>
    </nav>

    <main class="container dashboard-content">
        <div id="weather-result" class="weather-card hidden">
            <button id="close-weather-btn" class="weather-card-close" aria-label="Close">&times;</button>
            <h2 id="location-name">City Name</h2>
            <div class="weather-temp"><span id="temp-value">--</span>&deg;F</div>
            <div class="weather-condition-row">
                <div id="hi-lo-text" class="weather-hi-lo"></div>
                <div id="condition-text" class="weather-condition-text">Sunny</div>
                <div id="feels-like-text" class="weather-feels-like"></div>
            </div>

            <div class="weather-details">
                <div>
                    <div>Humidity</div>
                    <div id="humidity-value">--%</div>
                </div>
                <div>
                    <div>Wind</div>
                    <div id="wind-value">-- mph</div>
                </div>
                <div>
                    <div>Air Quality</div>
                    <div id="aqi-value">--</div>
                </div>
            </div>

            <div class="save-location-actions">
                <button id="save-location-btn" class="btn">Save Location</button>
            </div>
        </div>

        <% if (role === 'advanced') { %>
        <div id="precip-map-section" class="precip-map-section hidden">
            <h3>Radar Map</h3>
            <div class="radar-controls">
                <button id="radar-play-btn" class="btn radar-btn">&#9646;&#9646;</button>
                <span class="radar-time-label">Time:</span>
                <span id="radar-timestamp" class="radar-timestamp">--</span>
                <span id="radar-frame-label" class="radar-frame-label"></span>
            </div>
            <div id="precip-map"></div>
        </div>
        <% } %>

        <div id="hourly-report" class="hourly-report hidden">
            <h3>Hourly Report (3-hour intervals)</h3>
            <div id="hourly-report-list" class="hourly-grid"></div>
        </div>

        <div class="saved-locations">
            <h3><%= role === 'advanced' ? 'Your Prioritized Locations' : 'Your Saved Locations' %></h3>
            <div id="saved-locations-list" class="location-grid"></div>
        </div>
    </main>
</body>

</html>
